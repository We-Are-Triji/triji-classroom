rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasCurrentUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserRole() {
      return currentUserDoc().data.role;
    }

    function isAdmin() {
      return isSignedIn() &&
        hasCurrentUserDoc() &&
        currentUserRole() == 'admin';
    }

    function validName(value) {
      return value is string &&
        value.size() >= 2 &&
        value.size() <= 50 &&
        value.matches("^[A-Za-z\\s'-]+$");
    }

    function validEmail(value) {
      return value is string &&
        value.size() >= 5 &&
        value.size() <= 120 &&
        value.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$');
    }

    function validPreferences(value) {
      return value == null || (
        value is map &&
        value.keys().hasOnly(['tasks', 'announcements', 'freedom_wall']) &&
        (value.tasks == null || value.tasks is bool) &&
        (value.announcements == null || value.announcements is bool) &&
        (value.freedom_wall == null || value.freedom_wall is bool)
      );
    }

    function validPinnedList(value) {
      return value == null || (value is list && value.size() <= 50);
    }

    function canReadUser(userId) {
      return isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId} {
      allow read: if canReadUser(userId);

      allow create: if isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.keys().hasOnly(['firstName', 'lastName', 'email', 'createdAt']) &&
        validName(request.resource.data.firstName) &&
        validName(request.resource.data.lastName) &&
        validEmail(request.resource.data.email) &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.createdAt is string;

      allow update: if isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'firstName',
          'lastName',
          'expoPushToken',
          'notificationPermissionStatus',
          'notificationTokenUpdatedAt',
          'notificationPreferences',
          'pinnedTaskIds',
          'pinnedAnnouncementIds'
        ]) &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['firstName']) ||
          validName(request.resource.data.firstName)
        ) &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastName']) ||
          validName(request.resource.data.lastName)
        ) &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['expoPushToken']) ||
          (
            request.resource.data.expoPushToken is string &&
            request.resource.data.expoPushToken.size() <= 255
          )
        ) &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['notificationPermissionStatus']) ||
          (
            request.resource.data.notificationPermissionStatus == 'granted' ||
            request.resource.data.notificationPermissionStatus == 'denied' ||
            request.resource.data.notificationPermissionStatus == 'undetermined'
          )
        ) &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['notificationTokenUpdatedAt']) ||
          request.resource.data.notificationTokenUpdatedAt is string
        ) &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['notificationPreferences']) ||
          validPreferences(request.resource.data.notificationPreferences)
        ) &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['pinnedTaskIds']) ||
          validPinnedList(request.resource.data.pinnedTaskIds)
        ) &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['pinnedAnnouncementIds']) ||
          validPinnedList(request.resource.data.pinnedAnnouncementIds)
        );
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /freedom-wall-posts/{postId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /reports/{reportId} {
      allow read: if isSignedIn() &&
        (
          request.auth.uid == resource.data.userId ||
          request.auth.uid == resource.data.reporterId ||
          isAdmin()
        );
      allow create, update, delete: if false;
    }
  }
}
